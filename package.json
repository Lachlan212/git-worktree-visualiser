{
  "name": "git-worktree-panel",
  "version": "1.0.0",
  "description": "A floating panel to monitor git worktrees",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "build:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.yourname.git-worktree-panel",
    "productName": "Git Worktree Panel",
    "win": {
      "target": [
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "portable": {
      "artifactName": "GitWorktreePanel.exe"
    },
    "files": [
      "main.js",
      "index.html"
    ]
  }
}
